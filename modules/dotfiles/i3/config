
# Mod key = Windows Key
set $mod Mod4

# Monitors
set $mon1 DisplayPort-1
set $mon2 HDMI-A-0

# Font
font pango:JetBrains Mono 10 

# Autostart
exec --no-startup-id dunst
exec --no-startup-id picom

# Appearance
gaps inner 2
gaps outer 1
default_border pixel 2
default_floating_border pixel 2
smart_gaps on
smart_borders on

# Colors
set $bg       #1e1e2e
set $fg       #cdd6f4
set $accent   #89b4fa
set $urgent   #f38ba8
set $inactive #45475a

# class                 border    bg      text  indicator   child_border
client.focused          $accent   $bg     $fg   $accent     $accent
client.focused_inactive $inactive $bg     $fg   $inactive   $inactive
client.unfocused        $inactive $bg     $fg   $inactive   $inactive
client.urgent           $urgent   $urgent $fg   $urgent     $urgent

# Keybindings
# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# Terminal
bindsym $mod+Return exec alacritty

# Browser
bindsym $mod+b exec firefox

# Launcher
bindsym $mod+space exec --no-startup-id rofi -show drun

# Screenshot
bindsym $mod+Shift+s exec flameshot gui

# Kill focused window
bindsym $mod+q kill

# Window
bindsym $mod+Tab exec --no-startup-id rofi -show window

# Reload / restart i3
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart

# Focus
focus_follows_mouse no
focus_on_window_activation none

bindsym $mod+j focus down 
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+h focus left

# Arrow keys focus 
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move windows
bindsym $mod+Shift+j move down 
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
bindsym $mod+Shift+h move left

bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Layout
bindsym $mod+f fullscreen toggle
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+Shift+space floating toggle

# Workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"

# Pin workspaces to monitors
workspace $ws1 output $mon1
workspace $ws2 output $mon2
workspace $ws3 output $mon2
workspace $ws4 output $mon2

# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4

# Floating rules
for_window [class="Pavucontrol"] floating enable
for_window [class="Arandr"] floating enable
for_window [class="flameshot"] floating enable

# EVE Online - pin to monitor1 to prevent focus stealing
for_window [class="steam_app_8500"] floating enable
for_window [class="steam_app_8500"] move to workspace $ws1

# Bar - temporary until polybar is set up
bar {
  status_command i3status
  position top
  colors {
    background $bg
    statusline $fg
    separator $inactive
    focused_workspace   $accent   $bg $fg
    active_workspace    $inactive $bg $fg
    inactive_workspace  $bg       $bg $inactive
    urgent_workspace    $urgent   $bg $fg
  }
}

# exit i3 (logs you out of your X session)
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"

bindsym $mod+r mode "resize"
